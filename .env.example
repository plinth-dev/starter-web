# Plinth starter-web — example env. Copy to .env.local (gitignored) and edit.

NODE_ENV=development
APP_ENV=dev
SERVICE_NAME=starter-web
SERVICE_VERSION=0.1.0-dev

# starter-api address. Default assumes both run on localhost.
API_BASE_URL=http://localhost:8080

# Cerbos PDP. Same address starter-api uses; starter-web hits it for
# permissionMap calls in route layouts.
CERBOS_ADDRESS=localhost:3593
CERBOS_TLS=false

# OTel collector — server runtime. Empty disables export.
OTEL_EXPORTER_OTLP_ENDPOINT=

# OTel browser SDK — `NEXT_PUBLIC_*` are inlined into the client bundle.
NEXT_PUBLIC_SERVICE_NAME=starter-web
NEXT_PUBLIC_SERVICE_VERSION=0.1.0-dev
NEXT_PUBLIC_MODULE_NAME=items
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_OTEL_EXPORTER_ENDPOINT=
