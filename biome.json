{
  "$schema": "https://biomejs.dev/schemas/2.4.0/schema.json",
  "files": {
    "ignoreUnknown": true,
    "experimentalScannerIgnores": [".next", "node_modules", "next-env.d.ts"]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
